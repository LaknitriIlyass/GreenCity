doctype html
html
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")

    title Green City

    // Bootstrap
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css")

    // Font Awesome
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")

    // CSS tuo
    link(rel="stylesheet", href="/css/style.css")

  body.d-flex.flex-column.min-vh-100.bg-light

    // NAVBAR
    nav.navbar.navbar-light.bg-white.shadow-sm
      div.container-fluid
        a.navbar-brand(href="/") Green City
        a(href="/login")
          i.fas.fa-user.fs-4

    // CONTENUTO PAGINA
    main.flex-fill.d-flex.align-items-center.justify-content-center
      block content

    // FOOTER
    footer.text-center.p-3.bg-white.mt-auto.shadow-sm
      p.mb-0 © 2026 Green City

    // Bootstrap JS
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js")