extends layout

block content

  div.gc-page

    div.gc-page-header
      a.gc-back(href="/") ← Torna alla home
      h1.gc-page-title #{nome}
      p.gc-page-subtitle #{paese}

    //- AQI principale
    div.gc-card.mb-4
      div.row.align-items-center
        div.col-md-4.text-center.mb-3.mb-md-0
          p.gc-label.text-uppercase.mb-1 Indice AQI europeo
          div.gc-aqi-big(class=`aqi-${aria.livello.classe}`) #{aria.aqi}
          span.gc-badge(class=`gc-badge-${aria.livello.classe}`) #{aria.livello.emoji} #{aria.livello.testo}
        div.col-md-8
          p.gc-label.mb-1 Posizione sulla scala
          div.gc-aqi-bar.mb-3
            div.gc-aqi-bar-track
            div.gc-aqi-marker(style=`left: calc(${Math.min(aria.aqi, 100)}% - 10px)`) ▼
          div.d-flex.justify-content-between.gc-muted.small
            span 0
            span 20
            span 40
            span 60
            span 80
            span 100+
          p.gc-muted.small.mt-2.mb-0
            | Dati aggiornati ogni ora · Fonte:&nbsp;
            a(href="https://open-meteo.com" target="_blank") Open-Meteo Air Quality

    //- Inquinanti
    h5.gc-section-title Inquinanti attuali
    div.row.g-3.mb-4

      div.col-6.col-lg-3
        div.gc-card.h-100
          p.gc-label.mb-1 PM2.5
          h4.gc-stat #{aria.pm25} #[small.gc-muted µg/m³]
          p.gc-muted.small.mb-0 Particelle fini · limite OMS: 15

      div.col-6.col-lg-3
        div.gc-card.h-100
          p.gc-label.mb-1 PM10
          h4.gc-stat #{aria.pm10} #[small.gc-muted µg/m³]
          p.gc-muted.small.mb-0 Polveri grossolane · limite OMS: 45

      div.col-6.col-lg-3
        div.gc-card.h-100
          p.gc-label.mb-1 NO₂
          h4.gc-stat #{aria.no2} #[small.gc-muted µg/m³]
          p.gc-muted.small.mb-0 Traffico e combustioni

      div.col-6.col-lg-3
        div.gc-card.h-100
          p.gc-label.mb-1 O₃ Ozono
          h4.gc-stat #{aria.o3} #[small.gc-muted µg/m³]
          p.gc-muted.small.mb-0 Si forma con calore e luce

      div.col-6.col-lg-3
        div.gc-card.h-100
          p.gc-label.mb-1 SO₂
          h4.gc-stat #{aria.so2} #[small.gc-muted µg/m³]
          p.gc-muted.small.mb-0 Industrie e centrali

      div.col-6.col-lg-3
        div.gc-card.h-100
          p.gc-label.mb-1 CO
          h4.gc-stat #{aria.co} #[small.gc-muted µg/m³]
          p.gc-muted.small.mb-0 Combustioni incomplete

      div.col-6.col-lg-3
        div.gc-card.h-100
          p.gc-label.mb-1 Polveri
          h4.gc-stat #{aria.polveri} #[small.gc-muted µg/m³]
          p.gc-muted.small.mb-0 Polveri minerali e sabbia

      div.col-6.col-lg-3
        div.gc-card.h-100
          p.gc-label.mb-1 Indice UV
          h4.gc-stat #{aria.uv}
          p.gc-muted.small.mb-0 Radiazione ultravioletta

    //- Grafici 7 giorni
    h5.gc-section-title Andamento ultimi 7 giorni

    div.gc-btn-group.mb-3
      button.gc-tab.active#btnAqi(type="button") AQI
      button.gc-tab#btnPm(type="button") PM2.5 / PM10
      button.gc-tab#btnGas(type="button") NO₂ / O₃

    div.gc-card.mb-4
      canvas#grafico(height="100")

    //- Meteo
    h5.gc-section-title Condizioni meteo
    div.row.g-3

      div.col-6.col-md-3
        div.gc-card.text-center
          p.gc-label.mb-1  Temperatura
          h4.gc-stat #{meteo.temperature}°C

      div.col-6.col-md-3
        div.gc-card.text-center
          p.gc-label.mb-1  Vento
          h4.gc-stat #{meteo.windspeed} km/h

      div.col-6.col-md-3
        div.gc-card.text-center
          p.gc-label.mb-1  Direzione
          h4.gc-stat #{meteo.winddirection}°

block scripts
  script(src="https://cdn.jsdelivr.net/npm/chart.js")
  script.
    const storico = !{storico};
    const ctx = document.getElementById('grafico').getContext('2d');

    Chart.defaults.color = '#94a3b8';
    Chart.defaults.borderColor = 'rgba(255,255,255,0.06)';

    const datasets = {
      aqi: [{
        label: 'AQI europeo',
        data: storico.aqi,
        borderColor: '#34d399',
        backgroundColor: 'rgba(52,211,153,0.1)',
        fill: true, tension: 0.3
      }],
      pm: [
        {
          label: 'PM2.5 (µg/m³)',
          data: storico.pm25,
          borderColor: '#f87171',
          backgroundColor: 'rgba(248,113,113,0.1)',
          fill: true, tension: 0.3
        },
        {
          label: 'PM10 (µg/m³)',
          data: storico.pm10,
          borderColor: '#fb923c',
          backgroundColor: 'rgba(251,146,60,0.1)',
          fill: true, tension: 0.3
        }
      ],
      gas: [
        {
          label: 'NO₂ (µg/m³)',
          data: storico.no2,
          borderColor: '#a78bfa',
          backgroundColor: 'rgba(167,139,250,0.1)',
          fill: true, tension: 0.3
        },
        {
          label: 'O₃ (µg/m³)',
          data: storico.o3,
          borderColor: '#38bdf8',
          backgroundColor: 'rgba(56,189,248,0.1)',
          fill: true, tension: 0.3
        }
      ]
    };

    const grafico = new Chart(ctx, {
      type: 'line',
      data: { labels: storico.labels, datasets: datasets.aqi },
      options: {
        responsive: true,
        plugins: {
          legend: { position: 'top' },
          tooltip: { mode: 'index', intersect: false }
        },
        scales: {
          y: { beginAtZero: true },
          x: { grid: { display: false } }
        }
      }
    });

    function setGrafico(tipo, btnId) {
      grafico.data.datasets = datasets[tipo];
      grafico.update();
      document.querySelectorAll('.gc-tab').forEach(b => b.classList.remove('active'));
      document.getElementById(btnId).classList.add('active');
    }

    document.getElementById('btnAqi').addEventListener('click', () => setGrafico('aqi', 'btnAqi'));
    document.getElementById('btnPm').addEventListener('click',  () => setGrafico('pm',  'btnPm'));
    document.getElementById('btnGas').addEventListener('click', () => setGrafico('gas', 'btnGas'));
